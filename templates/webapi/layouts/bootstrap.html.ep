<!DOCTYPE html>
<html lang="en">
  <head>
      <!-- Meta, title, CSS, favicons, etc. -->
      <meta charset="utf-8">
      <meta http-equiv="X-UA-Compatible" content="IE=edge">
      <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
      <meta name="description" content="openQA is a testing framework mainly for distributions">
      <meta name="keywords" content="Testing, Linux, Qemu">
      <meta name="author" content="openQA contributors">

      <meta name="csrf-token" content="<%= csrf_token %>">
      <meta name="csrf-param" content="csrf_token">
      <meta name="render-batch-size" content="<%= app->config->{webui}->{render_batch_size} %>">

      % if ($title) {
      <title><%= $appname . ": " . title %></title>
      % } else
      % {
      <title><%= $appname %></title>
      % }

      <!-- Bootstrap core CSS -->
      %= asset 'bootstrap.css'
      %= asset 'bootstrap.js'

      %= content_for 'head'

      %= javascript begin
          %= content_for 'head_javascript'
          function urlWithBase(path) {
            % my $url_base = url_for 'index';
            % if ($url_base eq '/') {
              return path;
            % } else {
              return '<%= $url_base %>' + path;
            % }
          }
          $(function() {
            setupForAll();
            backToTop();
            %= content_for 'ready_function'
          });
      % end

      <link id="favicon-16" rel="icon" href="<%= favicon_url '-16.png' %>" sizes="16x16" type="image/png">
      <link id="favicon-svg" rel="icon" href="<%= favicon_url '.svg' %>" sizes="any" type="image/svg+xml">

      <script>
        let theme = '<%= current_theme %>';
        
        if (theme === 'detect') theme = window.matchMedia('(prefers-color-scheme: dark)').matches === true ? 'dark' : 'light';
        
        // Normalize theme name for comparison (lowercase, replace spaces with hyphens)
        const normalizedTheme = theme.toLowerCase().replace(/\s+/g, '-');
        
        // Check if it's a Catppuccin variant (handle both catpuccin and catppuccin spellings)
        const isCatppuccin = normalizedTheme.startsWith('catppuccin') || normalizedTheme.startsWith('catpuccin');
        
        // Set Bootstrap theme
        if (isCatppuccin) {
          // Latte is light, others are dark
          const isLatte = normalizedTheme.includes('latte');
          document.documentElement.dataset.bsTheme = isLatte ? 'light' : 'dark';
          
          // Add ONLY the specific variant class (not the base theme-catppuccin)
          if (normalizedTheme.includes('latte')) {
            document.documentElement.classList.add('theme-catppuccin-latte');
          } else if (normalizedTheme.includes('frappe') || normalizedTheme.includes('frappé')) {
            document.documentElement.classList.add('theme-catppuccin-frappe');
          } else if (normalizedTheme.includes('macchiato')) {
            document.documentElement.classList.add('theme-catppuccin-macchiato');
          } else {
            // Default to Mocha for any other catppuccin variant
            document.documentElement.classList.add('theme-catppuccin');
          }
        } else {
          document.documentElement.dataset.bsTheme = theme;
          if (theme === 'dark') {
            document.documentElement.classList.add('theme-dark');
          }
        }
      </script>

  </head>
  <body>
      %= include 'layouts/navbar'
      <div class="container-fluid" id="content">
          %= content
          <button id="back-to-top" class="btn btn-primary btn-lg back-to-top">
            <i class="fa-solid fa-angle-up"></i>
          </button>
      </div>

      <footer class='footer'>
          <div class='container-fluid'>
              <div id="footer-links">
                  <span class="left">
                      %= include_branding 'links_footer_left'
                  </span>
                  <span class="right">
                      %= include_branding 'links_footer_right'
                  </span>
              </div>
              <div id='footer-legal' class="text-center">
                  <a href='https://github.com/os-autoinst/openQA/blob/master/docs/PrivacyPolicy.md'>Privacy Policy</a> -
                  openQA is licensed under
                  %= link_to 'GPL-2.0' => 'https://github.com/os-autoinst/openQA'
                  % if ($current_version) {
                      - Version
                      %= link_to $current_version => url_for('changelog')
                  % }
              </div>
            </div>
      </footer>
  </body>
</html>
